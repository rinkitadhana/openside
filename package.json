{
  "name": "asap",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:core": "pnpm --filter core dev",

    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:core": "pnpm --filter core build",

    "lint": "pnpm -r lint",

    "db:generate": "pnpm --filter core db:generate",
    "db:push": "pnpm --filter core db:push",
    "db:migrate": "pnpm --filter core db:migrate",
    "db:studio": "pnpm --filter core db:studio",
    "db:seed": "pnpm --filter core db:seed",
    "db:status": "pnpm --filter core db:status",
    "db:reset": "pnpm --filter core db:reset"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}
